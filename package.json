{
  "name": "crucible",
  "displayName": "Crucible - Roblox package manager built on rojo",
  "description": "Crucible for VS Code",
  "version": "2.0.0",
  "repository": "https://github.com/FootGod-bot/Crucible",
  "publisher": "FootGod",
  "engines": {
    "vscode": "^1.63.0"
  },
  "icon": "assets/extension-icon.png",
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:vscode-rojo.openMenu",
    "workspaceContains:*.project.json",
    "onView:cruciblePackages"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "vscode-rojo.openMenu",
        "title": "Open Menu",
        "category": "Rojo"
      },
      {
        "command": "vscode-crucible.addPackage",
        "title": "Add a Package",
        "category": "Crucible",
        "icon": "$(add)"
      },
      {
        "command": "vscode-crucible.removePackage",
        "title": "Remove a Package",
        "category": "Crucible",
        "icon": "$(close)"
      },
      {
        "command": "vscode-crucible.refreshPackages",
        "title": "Refresh Packages",
        "category": "Crucible",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "cruciblePackages",
          "name": "Crucible Packages",
          "icon": "$(package)",
          "contextualTitle": "Crucible Packages"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "vscode-crucible.addPackage",
          "when": "view == cruciblePackages",
          "group": "navigation"
        },
        {
          "command": "vscode-crucible.refreshPackages",
          "when": "view == cruciblePackages",
          "group": "navigation"
        },
        {
          "command": "vscode-crucible.removePackage",
          "when": "view == cruciblePackages",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "vscode-crucible.removePackage",
          "when": "view == cruciblePackages && viewItem == cruciblePackage",
          "group": "7_modification"
        }
      ]
    },
    "jsonValidation": [
      {
        "fileMatch": "*.project.json",
        "url": "./dist/project.schema.json"
      },
      {
        "fileMatch": "*.project.jsonc",
        "url": "./dist/project.schema.json"
      }
    ],
    "configuration": {
      "title": "Rojo",
      "properties": {
        "rojo.additionalProjectPaths": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "scope": "resource",
          "title": "Additional Project Paths",
          "description": "Additional folders to search for .project.json files beyond the workspace root"
        },
        "rojo.projectPathDisplay": {
          "type": "string",
          "enum": [
            "never",
            "asNeeded",
            "always"
          ],
          "enumDescriptions": [
            "Show only project file names.",
            "Show paths only when multiple projects have the same name.",
            "Always show full relative paths to project files."
          ],
          "default": "asNeeded",
          "scope": "resource",
          "title": "Project Path Display",
          "description": "Controls how project file paths are displayed in the project selection menu."
        },
        "rojo.showFullPath": {
          "type": "string",
          "enum": [
            "never",
            "asNeeded",
            "always"
          ],
          "enumDescriptions": [
            "Never show full paths in project details.",
            "Show full paths only for external projects or when project names are truncated.",
            "Always show full paths in project details."
          ],
          "default": "asNeeded",
          "scope": "resource",
          "title": "Show Full Path",
          "description": "Controls when full file paths are shown in the project selection menu details."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/glob": "^7.1.4",
    "@types/node": "14.x",
    "@types/unzipper": "^0.10.5",
    "@types/vscode": "^1.63.0",
    "@types/which": "^2.0.1",
    "@typescript-eslint/eslint-plugin": "^5.1.0",
    "@typescript-eslint/parser": "^5.1.0",
    "eslint": "^8.1.0",
    "glob": "^7.1.7",
    "node-fetch": "^3.2.4",
    "ts-loader": "^9.2.5",
    "typescript": "^4.4.4",
    "unzipper": "^0.10.11",
    "webpack": "^5.52.1",
    "webpack-cli": "^4.8.0",
    "which": "^2.0.2"
  }
}
